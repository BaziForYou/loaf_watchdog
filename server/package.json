    "license": "ISC",
    "dependencies": {
        "chokidar": "3.6.0",
        "typescript": "^5.8.3"
    },
    "devDependencies": {
        "@citizenfx/server": "2.0.14862-1",
        "@types/node": "^22.15.24",
        "esbuild": "0.25.5"
    },
    "prettier": {
        "tabWidth": 4,
        "singleQuote": true,
        "printWidth": 140,
        "semi": false,
        "quoteProps": "preserve",
        "trailingComma": "none"
