    "scripts": {
        "build": "esbuild server.ts --bundle --platform=node --target=node22 --outfile=dist/index.js --external:@babel/preset-typescript/package.json --external:@babel/plugin-transform-modules-commonjs --external:@babel/plugin-proposal-export-namespace-from",
        "watch": "pnpm build --watch"
    },
    "keywords": [],
